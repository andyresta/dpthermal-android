    <!-- Help / Bantuan Fragment -->
    <string name="help_title_bt">1. How to Connect to Bluetooth Printer</string>
    <string name="help_desc_bt">Open "Connection Settings" on the sidebar. Ensure Bluetooth and Location are active. Click "Scan Printers", select your thermal printer from the list, and make sure the status changes to "Connected".</string>
    
    <string name="help_title_spooler">2. How to Print PDF from Other Apps</string>
    <string name="help_desc_spooler">Enable DPThermal print service in Android settings (Settings -> Print -> Print Services -> Enable DPThermal). Once active, open a PDF document or Chrome browser, select "Print", then choose "DPThermal" as the destination printer.</string>
    
    <string name="help_title_bridge">3. How to Use Bridge Print (HTTP)</string>
    <string name="help_desc_bridge">Open "Bridge Print (HTTP)" menu and press "Start Server". This app will provide a local HTTP endpoint that can be hit with a JSON payload from your web app or Point of Sale (POS). See the example payload on that page.</string>

